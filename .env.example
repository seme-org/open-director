# =============================================================================
# Database
# =============================================================================
DATABASE_URL="mysql://opendirector:opendirector@mysql:3306/opendirector"
DIRECT_URL="mysql://opendirector:opendirector@mysql:3306/opendirector"

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SESSION_SECRET="change-me-in-production"

# =============================================================================
# LLM
# =============================================================================
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4o-mini"

# =============================================================================
# Media Generation Provider
# =============================================================================
# Provider: "aihubmix" (default, open-source friendly) or "wavespeed"
MEDIA_PROVIDER="aihubmix"

# --- AiHubMix (required when MEDIA_PROVIDER=aihubmix) ---
AIHUBMIX_API_KEY=""
# AIHUBMIX_IMAGE_MODEL="doubao-seedream-4-0"
# AIHUBMIX_IMAGE_EDIT_MODEL="qwen-image-edit-plus"
# TTS model: "tts-1-hd", "tts-1", "gpt-4o-mini-tts", or "edge" (free, uses Microsoft Edge TTS)
AIHUBMIX_TTS_MODEL="tts-1-hd"
# AIHUBMIX_TTS_VOICE="nova"
# Used when AIHUBMIX_TTS_MODEL=edge
# EDGE_TTS_VOICE="zh-CN-XiaoxiaoNeural"

# --- WaveSpeed (required when MEDIA_PROVIDER=wavespeed) ---
WAVESPEED_API_KEY=""
# WAVESPEED_RUNNER_CONCURRENCY="8"
# WAVESPEED_IMAGE_MODEL="google/nano-banana/text-to-image"
# WAVESPEED_IMAGE_TO_IMAGE_MODEL="bytedance/seedream-v4/edit"
# TTS model: "minimax/speech-02-turbo" (default) or "edge" (free)
# WAVESPEED_TTS_MODEL="minimax/speech-02-turbo"
# WAVESPEED_TTS_VOICE="Calm_Woman"
# Music model: "wavespeed-ai/ace-step-1.5" (default) or "local" (free, uses assets/bgm/default/)
# WAVESPEED_MUSIC_MODEL="wavespeed-ai/ace-step-1.5"

# =============================================================================
# Batch Mode
# =============================================================================
# Stock video search providers
PEXELS_API_KEY=""
PIXABAY_API_KEY=""

# TTS for batch mode (Edge TTS is free, no API key needed)
BATCH_TTS_PROVIDER="edge"
BATCH_EDGE_TTS_VOICE="zh-CN-XiaoxiaoNeural"
# BATCH_EDGE_TTS_PROXY=""

# =============================================================================
# Infrastructure
# =============================================================================
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_PASSWORD=""

S3_ENDPOINT="http://minio:9000"
S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="open-director"
S3_ACCESS_KEY_ID="opendirector"
S3_SECRET_ACCESS_KEY="opendirector-secret"
S3_FORCE_PATH_STYLE="true"

RENDER_QUEUE_NAME="open-director-render"
WORKER_CONCURRENCY="1"
# RENDER_DOWNLOAD_PROXY=""
