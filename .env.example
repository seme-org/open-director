# =============================================================================
# Database
# =============================================================================
DATABASE_URL="mysql://opendirector:opendirector@mysql:3306/opendirector"
DIRECT_URL="mysql://opendirector:opendirector@mysql:3306/opendirector"

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SESSION_SECRET="change-me-in-production"

# =============================================================================
# LLM
# =============================================================================
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4o-mini"

# =============================================================================
# Media Generation
# =============================================================================
WAVESPEED_API_KEY=""
# WAVESPEED_RUNNER_CONCURRENCY="8"
# Text-to-image model for character and location plates.
# WAVESPEED_IMAGE_MODEL="nano-banana"
# Image-to-image/edit model for storyboard frames with character references.
# Use an edit model here; using "nano-banana" will route to text-to-image and may ignore references.
# WAVESPEED_IMAGE_TO_IMAGE_MODEL="nano-banana-2-edit"
# Used by local Edge TTS.
# EDGE_TTS_VOICE="zh-CN-XiaoxiaoNeural"

# =============================================================================
# Batch Mode
# =============================================================================
# Stock video search providers
PEXELS_API_KEY=""
PIXABAY_API_KEY=""

# TTS for batch mode (Edge TTS is free, no API key needed)
BATCH_TTS_PROVIDER="edge"
BATCH_EDGE_TTS_VOICE="zh-CN-XiaoxiaoNeural"
# BATCH_EDGE_TTS_PROXY=""

# =============================================================================
# Infrastructure
# =============================================================================
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_PASSWORD=""

S3_ENDPOINT="http://minio:9000"
S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="open-director"
S3_ACCESS_KEY_ID="opendirector"
S3_SECRET_ACCESS_KEY="opendirector-secret"
S3_FORCE_PATH_STYLE="true"

RENDER_QUEUE_NAME="open-director-render"
WORKER_CONCURRENCY="1"
# RENDER_DOWNLOAD_PROXY=""
