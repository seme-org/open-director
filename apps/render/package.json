{
  "name": "@open-director/render",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/index.ts",
    "build": "prisma generate --schema ../../prisma/schema.prisma && tsup src/index.ts --format esm --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/lib-storage": "^3.948.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.71.1",
    "ffcreator": "^7.5.8",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.3.0",
    "https-proxy-agent": "^9.0.0",
    "ioredis": "^5.10.1",
    "uuid": "^11.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.9",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
